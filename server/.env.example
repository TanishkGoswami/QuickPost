# Supabase Configuration (Project B — gap_social_pilot)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Service role key is REQUIRED for SSO (auth.admin.generateLink + sso_nonces RLS bypass)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# SSO — shared secret with getaipilot.in's SOCIAL_PILOT_SSO_SECRET edge-function secret
# Must be the same value on both sides. Generate with: openssl rand -hex 32
SOCIAL_PILOT_SSO_SECRET=your-sso-shared-secret-here

# Hub sync (optional — for syncing social users back to hub DB)
HUB_SYNC_FUNCTION_URL=https://your-hub-project.supabase.co/functions/v1/sync-from-social
SOCIAL_SYNC_SECRET=your-sync-secret-here

# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Google OAuth (YouTube)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Instagram/Facebook OAuth
INSTAGRAM_APP_ID=your-facebook-app-id
INSTAGRAM_APP_SECRET=your-facebook-app-secret
INSTAGRAM_REDIRECT_URI=http://localhost:5000/auth/instagram/callback

# Public URL for video access (required for Instagram)
SERVER_PUBLIC_URL=http://localhost:5000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SESSION_SECRET=your-session-secret-key

# Reddit OAuth
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_REDIRECT_URI=http://localhost:5000/api/auth/reddit/callback
