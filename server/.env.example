PORT=5000
CLIENT_URL=http://localhost:5173
SERVER_PUBLIC_URL=https://your-ngrok-url.ngrok-free.dev

# For production VPS:
# CLIENT_URL=https://social.getaipilot.in
# SERVER_PUBLIC_URL=https://api.getaipilot.in

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Trend feed ingestion
YOUTUBE_DATA_API_KEY=
TREND_YOUTUBE_CRON=0 */2 * * *
TREND_YOUTUBE_REGIONS=IN
TREND_YOUTUBE_CATEGORY_IDS=
TREND_YOUTUBE_MAX_RESULTS=25

# Reddit trend ingestion uses the official OAuth API only. Keep usage within Reddit's free-tier/non-commercial limits.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=QuickPost-Trends/1.0.0
TREND_REDDIT_CRON=30 */3 * * *
TREND_REDDIT_SUBREDDITS=ChatGPT,ArtificialInteligence,ContentMarketing
TREND_REDDIT_LIMIT=25

# Bluesky trend ingestion uses the public Jetstream firehose, no credentials.
TREND_BLUESKY_JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
TREND_BLUESKY_BATCH_SIZE=25
TREND_BLUESKY_FLUSH_MS=10000
TREND_BLUESKY_INCLUDE_REPLIES=false
AUTODM_SUPABASE_URL=
AUTODM_SUPABASE_SERVICE_KEY=
AUTODM_SUPABASE_JWT_SECRET=
AUTODM_TOKEN_ENCRYPTION_KEY_BASE64=

# BullMQ broadcast worker
# Use a managed Redis/Valkey URL in production, for example Upstash/Redis Cloud.
REDIS_URL=redis://localhost:6379
TREND_FEED_CACHE_TTL_SECONDS=60
BROADCAST_QUEUE_NAME=broadcast-publish
BROADCAST_WORKER_CONCURRENCY=5
BROADCAST_MAX_ATTEMPTS=5
SCHEDULER_BATCH_SIZE=25
SCHEDULER_CRON=*/15 * * * * *
SCHEDULER_STALE_PROCESSING_MINUTES=15

# Local OAuth callbacks should use your ngrok URL.
# Production OAuth callbacks should use https://api.getaipilot.in.
INSTAGRAM_REDIRECT_URI=https://your-ngrok-url.ngrok-free.dev/api/auth/instagram/callback

# Pinterest Official OAuth 2.0 Credentials
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:5000/api/auth/pinterest/callback

# BullMQ and Scheduler Settings
BROADCAST_QUEUE_NAME=broadcast-publish
BROADCAST_WORKER_CONCURRENCY=5
BROADCAST_MAX_ATTEMPTS=5
SCHEDULER_BATCH_SIZE=25
SCHEDULER_CRON="*/15 * * * * *"
SCHEDULER_STALE_PROCESSING_MINUTES=15

# SupermailBox CPaaS Integration
SUPERMAILBOX_API_KEY=your_supermailbox_api_key_here

# Hub (GetAiPilot) Configuration
HUB_SUPABASE_URL=
HUB_SUPABASE_ANON_KEY=
