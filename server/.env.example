PORT=5000
CLIENT_URL=http://localhost:5173
SERVER_PUBLIC_URL=https://your-ngrok-url.ngrok-free.dev

# For production VPS:
# CLIENT_URL=https://social.getaipilot.in
# SERVER_PUBLIC_URL=https://api.getaipilot.in

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
AUTODM_SUPABASE_URL=
AUTODM_SUPABASE_SERVICE_KEY=
AUTODM_SUPABASE_JWT_SECRET=
AUTODM_TOKEN_ENCRYPTION_KEY_BASE64=
# Must be the SAME 32-byte base64 key as TOKEN_ENCRYPTION_KEY_BASE64 below.
# This key must also be set as a Supabase Secret named TOKEN_ENCRYPTION_KEY_BASE64
# on your Supabase project (Settings > Edge Functions > Secrets).
TOKEN_ENCRYPTION_KEY_BASE64=

# Trends/news enrichment
SERPAPI_KEY=

# Local OAuth callbacks should use your ngrok URL.
# Production OAuth callbacks should use https://api.getaipilot.in.
INSTAGRAM_REDIRECT_URI=https://your-ngrok-url.ngrok-free.dev/api/auth/instagram/callback
