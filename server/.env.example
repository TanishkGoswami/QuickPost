# SERVER_PUBLIC_URL=https://api.getaipilot.in

SUPABASE_URL=
SUPABASE_SERVICE_KEY=
AUTODM_SUPABASE_URL=
AUTODM_SUPABASE_SERVICE_KEY=
AUTODM_SUPABASE_JWT_SECRET=
AUTODM_TOKEN_ENCRYPTION_KEY_BASE64=

# Trends/news enrichment
SERPAPI_KEY=

# BullMQ broadcast worker
# Use a managed Redis/Valkey URL in production, for example Upstash/Redis Cloud.
REDIS_URL=redis://localhost:6379
BROADCAST_QUEUE_NAME=broadcast-publish
BROADCAST_WORKER_CONCURRENCY=5
BROADCAST_MAX_ATTEMPTS=5
SCHEDULER_BATCH_SIZE=25
SCHEDULER_CRON=*/15 * * * * *
SCHEDULER_STALE_PROCESSING_MINUTES=15

# Local OAuth callbacks should use your ngrok URL.
# Production OAuth callbacks should use https://api.getaipilot.in.
INSTAGRAM_REDIRECT_URI=https://your-ngrok-url.ngrok-free.dev/api/auth/instagram/callback

# BullMQ and Scheduler Settings
BROADCAST_QUEUE_NAME=broadcast-publish
BROADCAST_WORKER_CONCURRENCY=5
BROADCAST_MAX_ATTEMPTS=5
SCHEDULER_BATCH_SIZE=25
SCHEDULER_CRON="*/15 * * * * *"
SCHEDULER_STALE_PROCESSING_MINUTES=15

# SupermailBox CPaaS Integration
SUPERMAILBOX_API_KEY=your_supermailbox_api_key_here

# Hub (GetAiPilot) Configuration
