# Vercel frontend env
# Add these in Vercel Project Settings > Environment Variables.

VITE_API_URL=https://your-backend-domain.com

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Trend feed reads use the same Supabase project. Keep source API keys server-side only.

VITE_AUTODM_SUPABASE_URL=https://your-autodm-project.supabase.co
VITE_AUTODM_SUPABASE_ANON_KEY=your_autodm_supabase_anon_key

# Optional: only set these if the deployed frontend uses Hub sync checks.
VITE_HUB_SUPABASE_ANON_KEY=your_hub_supabase_anon_key
VITE_HUB_SYNC_FUNCTION_URL=https://your-hub-project.supabase.co/functions/v1/sync-to-hub
VITE_HUB_CHECK_URL=https://your-hub-project.supabase.co/functions/v1/check-sync
