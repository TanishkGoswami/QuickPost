# Local testing:
# - VITE_API_URL is used by OAuth/connect redirects.
# - VITE_DEV_API_URL is used by Vite's /api proxy during `npm run dev`.
# Use your current ngrok backend URL here.
VITE_API_URL=https://your-ngrok-url.ngrok-free.dev
VITE_DEV_API_URL=https://your-ngrok-url.ngrok-free.dev

# Production builds override this in .env.production:
# VITE_API_URL=https://api.getaipilot.in
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_AUTODM_SUPABASE_URL=
VITE_AUTODM_SUPABASE_ANON_KEY=
